# cross-agent-memory-kit environment template
# Copy to `.env` and fill in. .env is gitignored.

# =============================================================================
# LangSmith tracing for the post-session distillation hook (optional)
# =============================================================================
# When LANGSMITH_TRACING=true and LANGSMITH_API_KEY is set, every distillation
# call is traced into the LangSmith project below. The hook still runs if these
# are unset; tracing is just disabled.
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mcp-memory-service-hook

# =============================================================================
# Provider API keys - only needed for the providers you actually enable in
# config/providers.yaml. Subscription-billed CLI providers (claude-cli,
# codex-cli, gemini-cli, cursor-cli) need NO key here - they use the binary's
# own login.
# =============================================================================

# Anthropic direct API (provider: anthropic-api)
ANTHROPIC_API_KEY=

# OpenAI direct API (provider: openai-api)
OPENAI_API_KEY=

# Google Gemini direct API (provider: gemini-api)
GOOGLE_API_KEY=

# OpenRouter (provider: openrouter-api) - one key, hundreds of models
OPENROUTER_API_KEY=

# =============================================================================
# Optional: client/project registry for slug tagging
# =============================================================================
# Point this at a YAML file describing your projects so the distiller tags each
# memory with a canonical slug. Opt-in; leave unset to skip. See distill/registry.py
# for the expected shape.
# MCP_MEMORY_CLIENTS_YAML=~/path/to/clients.yaml

# =============================================================================
# Optional: multi-user routing (shared account; see MULTI-USER.md)
# =============================================================================
# Set by onboard_multiuser.py when one agent account is shared by several people
# and each needs a private + shared memory store. The post-session hook reads
# this file, so these route distilled memories into THIS person's private store
# and tag them. Leave unset for a single-user install (behavior is unchanged).
#   MEMORY_OWNER          - this person's slug, becomes the owner:<slug> tag
#   MEMORY_DEFAULT_SCOPE  - scope:<value> tag for hook-written memories (private)
#   MCP_MEMORY_SQLITE_VEC_PATH - the PRIVATE local cache path the hook writes to
# MEMORY_OWNER=alice
# MEMORY_DEFAULT_SCOPE=private
# MCP_MEMORY_SQLITE_VEC_PATH=~/Library/Application Support/mcp-memory/private-alice/sqlite_vec.db

# =============================================================================
# Optional: multi-device sync via the Cloudflare hybrid backend
# =============================================================================
# These belong in the `memory` MCP server's `env` block (see MULTI-DEVICE-SYNC.md),
# not strictly in this .env, but they are listed here for reference. Keep the
# token secret and never commit it.
# MCP_MEMORY_STORAGE_BACKEND=hybrid
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_D1_DATABASE_ID=
# CLOUDFLARE_VECTORIZE_INDEX=mcp-memory
# CLOUDFLARE_EMBEDDING_MODEL=@cf/baai/bge-base-en-v1.5
# HYBRID_SYNC_ON_STARTUP=true
